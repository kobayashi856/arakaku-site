---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  breadcrumb?: { label: string; href: string }[];
}

const { title, description, breadcrumb } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- パンくず -->
    {breadcrumb && (
      <nav class="flex items-center gap-2 text-sm text-ak-silver mb-6">
        <a href="/" class="hover:text-white transition-colors">TOP</a>
        {breadcrumb.map((item) => (
          <>
            <span>/</span>
            <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
          </>
        ))}
      </nav>
    )}

    <!-- 記事ヘッダー -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-black text-white border-l-4 border-ak-red pl-4">{title}</h1>
    </div>

    <!-- 記事コンテンツ -->
    <div class="prose-ak">
      <slot />
    </div>
  </div>

  <style is:global>
    .prose-ak h2 {
      @apply text-2xl font-bold text-white mt-10 mb-4 pb-2 border-b border-gray-700;
    }
    .prose-ak h3 {
      @apply text-xl font-bold text-ak-gold mt-6 mb-3;
    }
    .prose-ak p {
      @apply text-gray-300 leading-relaxed mb-4;
    }
    .prose-ak ul {
      @apply list-disc list-inside text-gray-300 mb-4 space-y-1;
    }
    .prose-ak ol {
      @apply list-decimal list-inside text-gray-300 mb-4 space-y-1;
    }
    .prose-ak strong {
      @apply text-white font-bold;
    }
    .prose-ak table {
      @apply w-full border-collapse mb-6;
    }
    .prose-ak th {
      @apply bg-ak-dark text-ak-gold font-bold px-4 py-2 text-left border border-gray-700;
    }
    .prose-ak td {
      @apply px-4 py-2 text-gray-300 border border-gray-700;
    }
    .prose-ak tr:nth-child(even) td {
      @apply bg-white/5;
    }
  </style>
</BaseLayout>
