---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryColors: Record<string, string> = {
  '試合結果': 'bg-red-900/50 text-red-300 border-red-700/50',
  '大会情報': 'bg-purple-900/50 text-purple-300 border-purple-700/50',
  '選手情報': 'bg-blue-900/50 text-blue-300 border-blue-700/50',
  'お知らせ': 'bg-gray-700/50 text-gray-300 border-gray-600/50',
};
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="アラカクNEWS" description="アラカク最新情報・お知らせ">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- パンくず -->
    <nav class="flex items-center gap-2 text-sm text-ak-silver mb-6">
      <a href={base} class="hover:text-white">TOP</a>
      <span>/</span>
      <span>NEWS</span>
    </nav>

    <h1 class="text-3xl md:text-4xl font-black text-white border-l-4 border-ak-red pl-4 mb-8">アラカクNEWS</h1>

    <!-- ニュース一覧 -->
    <div class="space-y-4">
      {sortedNews.map((item) => (
        <a
          href={`${base}news/${item.slug}`}
          class="block bg-ak-dark rounded-xl border border-gray-700 p-5 hover:border-ak-red/50 hover:bg-white/5 transition-all group"
        >
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <span class="text-gray-500 text-sm font-mono">{item.data.date}</span>
            <span class={`text-xs font-bold px-2 py-0.5 rounded border ${categoryColors[item.data.category] ?? 'bg-gray-700/50 text-gray-300 border-gray-600/50'}`}>
              {item.data.category}
            </span>
          </div>
          <h2 class="text-lg font-black text-white group-hover:text-ak-gold transition-colors mb-1">
            {item.data.title}
          </h2>
          <p class="text-gray-400 text-sm">{item.data.summary}</p>
        </a>
      ))}
    </div>

    {sortedNews.length === 0 && (
      <div class="text-center py-16">
        <div class="text-4xl mb-4">📭</div>
        <p class="text-gray-400">まだニュースがありません</p>
      </div>
    )}

    <!-- 追加方法 -->
    <div class="mt-12 p-6 bg-ak-dark rounded-xl border border-gray-700">
      <h3 class="text-white font-bold mb-2">📝 ニュースの追加方法</h3>
      <p class="text-gray-400 text-sm mb-3">
        ニュース記事は <code class="text-ak-gold bg-gray-800 px-1 rounded">src/content/news/</code> フォルダにMarkdownファイルを追加します。
      </p>
      <div class="bg-gray-900 rounded-lg p-4 text-sm font-mono text-gray-300">
        <div class="text-gray-500 mb-1"># ファイル名: YYYY-MM-タイトル.md</div>
        <div>{`---`}</div>
        <div>title: "記事タイトル"</div>
        <div>date: "YYYY-MM-DD"</div>
        <div>category: "試合結果" # or 大会情報 / 選手情報 / お知らせ</div>
        <div>summary: "一行サマリー"</div>
        <div>{`---`}</div>
        <div class="mt-2 text-gray-500">記事本文（Markdown）...</div>
      </div>
    </div>
  </div>
</BaseLayout>
